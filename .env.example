# Copy to .env and adjust. docker compose reads .env automatically.

# Postgres (used by docker-compose and the Spring app)
POSTGRES_DB=majstr
POSTGRES_USER=majstr
POSTGRES_PASSWORD=change-me-in-local-dev

# Spring datasource (override only if needed)
DB_URL=jdbc:postgresql://localhost:5432/majstr
DB_USERNAME=majstr
DB_PASSWORD=change-me-in-local-dev

# JWT signing secret — MUST be at least 32 bytes (256 bits) for HS256.
# Generate one with: openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-string-at-least-32-bytes

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Spring profile
SPRING_PROFILES_ACTIVE=dev

# Refresh-token lifetime in days (session length). Default 30; rotation keeps it safe.
REFRESH_TOKEN_TTL_DAYS=30

# Web Push (VAPID). Leave blank in local dev — a push is then logged & skipped.
# Generate a stable keypair once for production (see README "Web Push"):
#   npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@majstr.app

# Sentry error monitoring. Leave blank in local dev — Sentry is then disabled
# (nothing is sent). Get the DSN from your Sentry project settings.
SENTRY_DSN=
# Environment tag for Sentry events (defaults to SPRING_PROFILES_ACTIVE).
SENTRY_ENVIRONMENT=dev

# File storage backend: local (filesystem, dev default) or s3 (Cloudflare R2 /
# any S3-compatible). Leave as local for dev — the R2_* vars are only read when
# STORAGE_KIND=s3.
STORAGE_KIND=local
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_REGION=auto

# First-admin auto-seed. Leave blank in dev (no-op). On a fresh prod DB, set both
# to create the initial ADMIN on startup; ignored once any ADMIN exists. Use a
# strong, unique password — it's BCrypt-hashed and never logged.
ADMIN_EMAIL=
ADMIN_PASSWORD=
